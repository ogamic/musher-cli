# musher CLI — folder-local config (#1027)
# Copy to `.env` in a workspace folder (or run `musher init`), then fill in.
# `.env` is gitignored; never commit a real token. `musher init` writes mode 0600.
#
# Precedence: real environment variables always win over these file values.

# API base URL (default http://localhost:3001)
MUSHER_API_URL=http://localhost:3001

# Personal access token (created in the web Settings panel). Acts as its user
# and inherits their role — keep it secret.
MUSHER_TOKEN=msh_your_token_here

# The board context for this folder — workspace slug (e.g. `musher`) or id.
MUSHER_WORKSPACE=musher
